<!doctype html>
<html lang="en" data-theme="light">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{% if title %}{{ title }} · {% endif %}Jenesis</title>
  <meta name="description" content="{{ description or 'Documentation for the Jenesis product family: a Java-native build tool, launcher, module catalogue, and artifact repository.' }}">
  <link rel="icon" href="/assets/logos/light/jenesis-tool.svg" media="(prefers-color-scheme: light)">
  <link rel="icon" href="/assets/logos/dark/jenesis-tool.svg" media="(prefers-color-scheme: dark)">
  <link rel="stylesheet" href="/assets/css/pico.min.css">
  <link rel="stylesheet" href="/assets/css/app.css">
  <link rel="stylesheet" href="/assets/css/docs.css">
  <!-- Set the theme before first paint so there is no flash. -->
  <script>
    (function () {
      var t = localStorage.getItem("jenesis-theme");
      if (t === "light" || t === "dark") document.documentElement.setAttribute("data-theme", t);
      else if (window.matchMedia("(prefers-color-scheme: dark)").matches) document.documentElement.setAttribute("data-theme", "dark");
    })();
  </script>
</head>
<body>
  <a class="skip-link" href="#main">Skip to content</a>
  <header class="site-header">
    <div class="site-header__inner">
      {% set brandLogo = "jenesis-" + (section or "tool") %}
      <a class="site-brand" href="/" aria-label="Jenesis home">
        <img class="site-brand__mark" src="/assets/logos/light/{{ brandLogo }}.svg" alt="" width="28" height="28" data-logo="{{ brandLogo }}">
        <span class="site-brand__name">Jenesis</span>
      </a>
      {% if section %}<button class="nav-toggle" aria-expanded="false" aria-controls="section-nav">Menu</button>{% endif %}
      <nav class="site-nav" aria-label="Products">
        {% for s in sections %}
          <a href="{{ s.url }}"{% if page.url.startsWith(s.url) %} aria-current="page"{% endif %}>{{ s.title }}</a>
        {% endfor %}
      </nav>
      {% for s in sections %}{% if s.key == section %}
        <a class="site-repo" href="{{ s.repo }}" title="{{ s.title }} on GitHub" aria-label="{{ s.title }} on GitHub">
          <svg class="site-repo__mark" width="18" height="18" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0016 8c0-4.42-3.58-8-8-8z"/></svg>
        </a>
      {% endif %}{% endfor %}
      <button class="theme-toggle" type="button" title="Switch theme" aria-label="Switch colour theme">◐</button>
    </div>
  </header>

  {{ content | safe }}

  <script src="/assets/js/theme.js" defer></script>
  <script src="/assets/js/nav.js" defer></script>
  <script src="/assets/js/version.js" defer></script>
</body>
</html>
